{
  "name": "@radish-ui/core",
  "version": "0.1.0",
  "description": "Headless react-admin wrappers and Tailwind utilities for radish-ui",
  "keywords": [
    "react-admin",
    "tailwindcss",
    "radish-ui",
    "headless",
    "ra-core",
    "ui",
    "components"
  ],
  "homepage": "https://saebyn.github.io/radish-ui/",
  "repository": {
    "type": "git",
    "url": "https://github.com/saebyn/radish-ui.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./preset": {
      "types": "./dist/preset.d.ts",
      "import": "./dist/preset.js",
      "require": "./dist/preset.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "ra-core": "^5.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "ra-core": "^5",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "tailwindcss": "^3 || ^4"
  }
}
