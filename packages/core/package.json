{
  "name": "@radish-ui/core",
  "version": "0.1.0-prerelease",
  "description": "Headless react-admin wrappers and Tailwind utilities for radish-ui",
  "keywords": [
    "components",
    "headless",
    "ra-core",
    "radish-ui",
    "react-admin",
    "tailwindcss",
    "ui"
  ],
  "homepage": "https://saebyn.github.io/radish-ui/",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/saebyn/radish-ui.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./preset": {
      "types": "./dist/preset.d.ts",
      "import": "./dist/preset.js",
      "require": "./dist/preset.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^18.3.7",
    "ra-core": "^5.3.3",
    "react": "^19.2.4",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "ra-core": "^5",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "tailwindcss": "^3 || ^4"
  }
}
