{
  "name": "radish-ui",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prepare": "pnpm --filter @radish-ui/core build && pnpm --filter @radish-ui/cli build",
    "build": "pnpm --filter @radish-ui/core build && pnpm --filter @radish-ui/cli build",
    "dev": "pnpm --filter @radish-ui/demo dev",
    "preview": "pnpm --filter @radish-ui/demo preview",
    "sync": "pnpm --filter @radish-ui/cli build && pnpm --filter @radish-ui/demo sync",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint ."
  },
  "devDependencies": {
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^5.4.5"
  }
}
